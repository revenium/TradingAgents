# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_CN_API_KEY=
ZHIPU_API_KEY=
ZHIPU_CN_API_KEY=
MINIMAX_API_KEY=
MINIMAX_CN_API_KEY=
OPENROUTER_API_KEY=
MISTRAL_API_KEY=
MOONSHOT_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# FRED (Federal Reserve macro data: rates, inflation, labor, growth). Free key: https://fred.stlouisfed.org/docs/api/api_key.html
#FRED_API_KEY=

# Optional: a custom OpenAI-compatible endpoint (vLLM, LM Studio, llama.cpp,
# relay). Select provider "openai_compatible" and set the base URL; the key is
# optional (local servers need none).
#OPENAI_COMPATIBLE_API_KEY=

# AWS Bedrock (provider "bedrock", install with: pip install ".[bedrock]").
# Auth uses the standard AWS credential chain; set the region (and optionally a
# named profile). No single API key.
#AWS_DEFAULT_REGION=us-west-2
#AWS_PROFILE=

# Optional: point at a remote Ollama server. When unset, defaults to
# the local instance at http://localhost:11434/v1. Convention follows
# the broader Ollama ecosystem; both the CLI dropdown and programmatic
# client pick this up.
#OLLAMA_BASE_URL=http://your-ollama-host:11434/v1

# Optional: override DEFAULT_CONFIG without editing code.
# Any TRADINGAGENTS_* variable below, when set, replaces the matching key
# in tradingagents/default_config.py. Values are coerced to the type of
# the existing default (bool / int / str), so "true"/"3" work as expected.
# In the CLI, setting the LLM provider / models / backend URL / language
# also skips the matching interactive selection step (useful for
# OpenAI-compatible endpoints like opencode or LM Studio, and unattended runs).
#TRADINGAGENTS_LLM_PROVIDER=openai
#TRADINGAGENTS_DEEP_THINK_LLM=gpt-5.4
#TRADINGAGENTS_QUICK_THINK_LLM=gpt-5.4-mini
#TRADINGAGENTS_LLM_BACKEND_URL=
#TRADINGAGENTS_OUTPUT_LANGUAGE=English
#TRADINGAGENTS_MAX_DEBATE_ROUNDS=1
#TRADINGAGENTS_MAX_RISK_ROUNDS=1
#TRADINGAGENTS_CHECKPOINT_ENABLED=false
# Sampling temperature (lower = less run-to-run variation on models that
# honor it). Unset leaves each provider at its default. See the README
# "Reproducibility" note — no setting makes LLM output fully deterministic.
#TRADINGAGENTS_TEMPERATURE=0.0

# Revenium AI cost metering (https://revenium.io). Metering is auto-enabled when
# REVENIUM_METERING_API_KEY is set; auto-disabled (silent no-op) when absent —
# so tests and offline runs pass without a real key.
# rev_mk_* = metering key  (required for cost metering and cost-control rules)
# rev_sk_* = write/management key (provisioned now via scripts/setup_revenium.py;
#            consumed in Phase 4 for billing monetization)
# Get both keys from: Revenium dashboard -> Settings -> API Keys
REVENIUM_METERING_API_KEY=
#REVENIUM_METERING_BASE_URL=https://api.revenium.ai
#REVENIUM_SK_API_KEY=
# Tenant ID — required for organization scoping (tenantId on GET + POST to /organizations).
# Find in: Revenium dashboard -> Settings -> Tenant / Organization.
#REVENIUM_TENANT_ID=
# Team ID — required for product scoping (teamId in product body + GET query to /products).
# Find in the Revenium dashboard URL or Settings -> Team.
#REVENIUM_TEAM_ID=
# Owner ID — required as ownerId in the product create body.
# Find in: Revenium dashboard -> Settings -> Team / Owner.
#REVENIUM_OWNER_ID=
# Platform management API base URL. Defaults to the production profitstream endpoint.
# Override for staging/dev environments only; do NOT change the metering URL above.
#REVENIUM_PLATFORM_BASE_URL=https://api.prod.ai.hcapp.io/profitstream/v2/api

# Revenium billing / monetize pillar (Phase 4, BIL-01/BIL-02, D-07/D-08).
# Set these in .env before a live demo run or when running validate_billing.py.
# When REVENIUM_SK_API_KEY is empty the billing emitter is a silent no-op (DMO-04).
#
# REVENIUM_SK_API_KEY is the rev_sk_* WRITE-scope key — the SAME key used for
#   scripts/setup_revenium.py provisioning and enforcement reads (GAP-04-LINK).
#   Do NOT use a metering-only rev_mk_* key: it is 403 on jobs write endpoints
#   and will cause create_job / report_outcome to fail silently in the billing
#   emitter.  An empty value disables all billing calls (DMO-04).
#   (Already set above under "Revenium AI cost metering" — no need to duplicate.)
#REVENIUM_SK_API_KEY=
#
# REVENIUM_PROFITSTREAM_BASE_URL must be HOST-ONLY (no path suffix).
#   Correct: https://api.prod.ai.hcapp.io
#   Wrong:   https://api.prod.ai.hcapp.io/profitstream/v2/api  ← SDK doubles the path → 404
#   The AgenticOutcomeClient appends /profitstream/v2/api itself; supplying the
#   full path produces a doubled path and a 404.
#   The default host https://api.revenium.io returns 403 on jobs write endpoints;
#   always override with the host-only form for live runs.
#REVENIUM_PROFITSTREAM_BASE_URL=https://api.prod.ai.hcapp.io

# Demo identity (D-01..D-03). Defaults are set in tradingagents/default_config.py.
# Override here only if you need to change the demo narrative or target a different
# Revenium org/product/subscriber.
#REVENIUM_ORGANIZATION_NAME=Revenium-Research-Desk
#REVENIUM_PRODUCT_NAME=trading-signal
#REVENIUM_SUBSCRIBER_ID=john.demic+trading@revenium.io

# Revenium cost-control circuit breaker (Phase 3 — CTL-01/CTL-04, D-09/D-10).
# These vars arm the enforcement gate that halts the run when the daily cost rule
# is breached.  All are commented-out by default so the keyless test suite remains
# green (DMO-04).  Set them in .env before a live demo run.
#
# REVENIUM_TEAM_ID (above) doubles as the enforcement polling scope — the circuit
# breaker fetches compiled rules from /ai/enforcement-rules/{team_id}.
# The dollar threshold lives in the Revenium rule itself (provisioned by
# scripts/setup_revenium.py), NOT in .env.
#
# Set to "true" to arm the circuit breaker enforcement gate; unset or "false" = no-op.
#REVENIUM_CIRCUIT_BREAKER_ENABLED=
#
# Base URL for the in-process enforcement gate (compiled-rules feed).
# Without the /profitstream context path the SDK derives the bare metering origin
# (https://api.revenium.ai) and the enforcement-rules fetch returns 404.
#REVENIUM_ENFORCEMENT_BASE_URL=https://api.revenium.ai/profitstream
# KEY-SCOPE: REVENIUM_METERING_API_KEY must have enforcement-rule READ scope.
#   A rev_sk_ write key works for BOTH metering and enforcement reads.
#   A metering-only rev_mk_ key is rejected (403) by the feed — the breaker
#   will never arm with a rev_mk_-only key.
#
# Poll interval for the background enforcement daemon (seconds).
# Default is 60s — too slow for a live demo halt.  Set to 5 for reliable demo timing
# (D-09): latency from rule breach to halt is approximately poll_interval + 5–30s.
#REVENIUM_CB_POLL_INTERVAL_SECONDS=
#
# Fail-mode when the enforcement cache is empty/uninitialized.
# "open" (default) = allow LLM calls through when cache not yet loaded; "closed" = block.
# Keep "open" for demo: enforcement starts at first poll, not at process start.
#REVENIUM_CB_FAIL_MODE=
#
# Set to "true" to disable all enforcement checks and keep the keyless test suite
# green (D-10/DMO-04).  Never set this in a live demo .env — it silently bypasses
# the circuit breaker and the halt will never fire.
#REVENIUM_BYPASS=

# Jentic tool metering / monetization (Phase 6, JEN-01 / T-06-01).
# Jentic provides managed-auth access to credentialed external APIs (e.g. newsapi.org).
# Each Jentic tool call is metered by Revenium and priced per the jentic:news price model.
# Get your API key from the Jentic dashboard: https://app.jentic.com
#
# JENTIC_AGENT_API_KEY: secret key for the Jentic gateway. NEVER log this value.
#   When empty (default), the Jentic tool is a fail-soft no-op (returns NO_DATA_AVAILABLE).
JENTIC_AGENT_API_KEY=
#
# JENTIC_TOOL_ENABLED: master toggle for the Jentic-backed news tool.
#   Set to "true" to enable; "false" or unset = disabled (no external API calls).
JENTIC_TOOL_ENABLED=false
#
# JENTIC_OP_ID: pinned Jentic operation-id for the newsapi.org getEverything endpoint.
#   Account-specific — update if your Jentic catalog has a different op-id.
#   Leave empty to fall back to a search-by-query path (slightly slower at demo time).
JENTIC_OP_ID=op_ba86fdce1bade1b7
#
# JENTIC_SEARCH_QUERY: fallback query when JENTIC_OP_ID is unset.
JENTIC_SEARCH_QUERY=
#
# JENTIC_TOOL_ID: stable Revenium toolId emitted in tool events and used as the
#   ToolResource key for per-call pricing. Must match the Revenium price model.
#   Do NOT change this after provisioning the price model — it breaks pricing attribution.
JENTIC_TOOL_ID=jentic:news
